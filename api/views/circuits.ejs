<!-- views/circuits.ejs -->
<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>MadaVoyages | Nos Circuits d'Exception</title>
    
    <!-- Bootstrap 5 & Google Fonts / Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Montserrat:wght=200;400;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <style>
        /* Variables Thématiques & Couleurs Premium */
        :root {
            --color-primary: #000c09;
            --color-secondary: #a53c19;
            --color-glow-gold: #ffd700;
            --color-surface-cream: #fbf9f5;
            --color-text-variant: #414846;
            
            --font-display: 'Playfair Display', serif;
            --font-body: 'Montserrat', sans-serif;
        }

        /* Base & Reset */
        html, body {
            width: 100%;
            max-width: 100%;
            overflow-x: hidden;
            background-color: var(--color-surface-cream);
            color: var(--color-primary);
            font-family: var(--font-body);
        }

        .magical-bg::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0.08;
            pointer-events: none;
            z-index: -1;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        section {
            position: relative;
            overflow: hidden !important;
            width: 100%;
        }

        .bg-sunset-amber { background: linear-gradient(180deg, #fbf9f5 0%, #fff4e5 100%); }
        .bg-sunset-glow { background: linear-gradient(180deg, #fff4e5 0%, #ffe9d1 100%); }
        .bg-sunset-warm { background: linear-gradient(180deg, #ffe9d1 0%, #fbf9f5 100%); }

        .font-display { font-family: var(--font-display); }
        .letter-magical { letter-spacing: 0.12em; }
        .label-caps { font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.15em; }
        .section-gap { padding-top: 100px; padding-bottom: 100px; }

        .golden-separator {
            width: 70px;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--color-glow-gold), transparent);
            margin: 1.5rem auto;
        }

        /* Barre de navigation Glassmorphism */
        .glass-nav {
            background: rgba(251, 249, 245, 0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            border-bottom: 1px solid rgba(165, 60, 25, 0.08);
            z-index: 1030;
        }
        
        .custom-navbar .nav-link {
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.12em;
            color: var(--color-primary) !important;
            position: relative;
            padding: 0.5rem 0;
            transition: color 0.3s ease;
        }
        .custom-navbar .nav-link:hover {
            color: var(--color-secondary) !important;
        }
        .custom-navbar .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; width: 100%; height: 2px;
            background-color: var(--color-secondary);
            transform: scaleX(0);
            transform-origin: right;
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .custom-navbar .nav-link:hover::after {
            transform: scaleX(1);
            transform-origin: left;
        }

        @media (max-width: 991.98px) {
            .navbar-collapse {
                position: fixed;
                top: 0; left: 0; width: 100vw; height: 100vh;
                background: rgba(251, 249, 245, 0.98) !important;
                backdrop-filter: blur(25px);
                -webkit-backdrop-filter: blur(25px);
                display: none;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                z-index: 1020;
                opacity: 0;
                transform: scale(1.02);
                transition: opacity 0.35s ease, transform 0.35s ease;
            }
            .navbar-collapse.show {
                display: flex !important;
                opacity: 1;
                transform: scale(1);
            }
            .custom-navbar .navbar-nav {
                gap: 2rem !important;
                text-align: center;
                margin-bottom: 2rem !important;
            }
            .custom-navbar .nav-link {
                font-family: var(--font-display);
                font-size: 26px;
                text-transform: none;
                font-style: italic;
                font-weight: 500;
            }
            .navbar-toggler { z-index: 1040; position: relative; }
        }

        /* Boutons Premium */
        .btn-premium {
            background-color: var(--color-primary);
            color: #fff;
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.15em;
            padding: 13px 32px;
            border-radius: 50px;
            border: none;
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            box-shadow: 0 4px 15px rgba(0, 12, 9, 0.15);
            display: inline-block;
        }
        .btn-premium:hover {
            background-color: var(--color-secondary);
            color: #fff;
            box-shadow: 0 0 25px rgba(165, 60, 25, 0.45);
            transform: translateY(-3px) scale(1.02);
        }

        .btn-outline-premium {
            background: transparent;
            color: var(--color-primary);
            border: 1px solid var(--color-primary);
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 0.15em;
            padding: 12px 28px;
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .btn-outline-premium:hover {
            background-color: var(--color-primary);
            color: #fff;
            transform: translateY(-2px);
        }

        /* Recherche & Filtres */
        .search-glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(165, 60, 25, 0.1);
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }
        .search-glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 45px rgba(165, 60, 25, 0.08);
        }

        /* Effets de zoom fluide et d'élévation Premium */
        .zoom-container {
            overflow: hidden;
            border-radius: 0px !important;
            transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .zoom-container img {
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .premium-card-hover {
            transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .premium-card-hover:hover .zoom-container {
            transform: translateY(-4px);
            box-shadow: 0 30px 60px rgba(0, 12, 9, 0.15) !important;
        }
        .premium-card-hover:hover .zoom-container img {
            transform: scale(1.06);
        }
        
        .content-box-hover {
            border-radius: 0px !important;
            transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .premium-card-hover:hover .content-box-hover {
            transform: translateY(-8px);
            box-shadow: 0 40px 80px rgba(165, 60, 25, 0.12) !important;
        }

        .tag-depart {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.18em;
            color: var(--color-secondary);
            text-transform: uppercase;
        }

        .btn-concierge-premium {
            background-color: #002219 !important;
            color: #ffd700 !important;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            padding: 16px 24px;
            border: none;
            border-radius: 0px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            transition: all 0.3s ease;
            text-decoration: none;
            cursor: pointer;
        }
        .btn-concierge-premium:hover {
            background-color: #003326 !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 34, 25, 0.3);
        }

        /* Historique Style Capture Concept */
        .history-card {
            background: #ffffff;
            border-left: 4px solid #ffc107;
            border-radius: 0px !important;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .history-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.05) !important;
        }
        .history-card.valide { border-left-color: #198754; }
        .history-card.annule { border-left-color: #dc3545; }

        .watermark-text {
            font-family: var(--font-display);
            font-size: 12vw; font-weight: 900;
            color: rgba(165, 60, 25, 0.03); pointer-events: none;
            white-space: nowrap; line-height: 1; user-select: none;
            will-change: transform;
        }

        .reveal {
            opacity: 0; transform: translateY(20px);
            transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .reveal.active { opacity: 1; transform: translateY(0); }

        .firefly-container { position: fixed; inset: 0; pointer-events: none; z-index: 2; overflow: hidden; }
        .firefly {
            position: absolute; width: 4px; height: 4px; background: #aacec3; border-radius: 50%;
            box-shadow: 0 0 10px #aacec3; opacity: 0; animation: floatUp linear infinite;
        }
        @keyframes floatUp {
            0% { transform: translateY(105vh) translateX(0); opacity: 0; }
            30% { opacity: 0.6; }
            80% { opacity: 0.6; }
            100% { transform: translateY(-5vh) translateX(25px); opacity: 0; }
        }

        .info-label { font-size: 9px; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2px; }
        .info-value { font-size: 13px; font-weight: 600; color: var(--color-primary); }
    </style>
</head>
<body class="magical-bg">

    <script id="voyages-data" type="application/json"><%- JSON.stringify(voyages || []) %></script>

    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: -2; pointer-events: none;">
        <canvas id="shader-canvas" class="w-100 h-100 d-block"></canvas>
    </div>
    <div class="firefly-container" id="firefly-container"></div>

    <header class="fixed-top glass-nav">
        <nav class="navbar navbar-expand-lg custom-navbar py-2 py-lg-3">
            <div class="container">
                <a class="navbar-brand font-display italic letter-magical fw-bold text-dark fs-4" href="/">MadaVoyages</a>
                <button class="navbar-toggler border-0 p-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="material-symbols-outlined text-dark fs-2">menu</span>
                </button>
                
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
                        <li class="nav-item"><a class="nav-link" href="/#evasions">Nos Évasions</a></li>
                        <li class="nav-item"><a class="nav-link" href="#explorer">Nos Circuits</a></li>
                        <li class="nav-item"><a class="nav-link" href="/#a-propos">À Propos</a></li>
                        <li class="nav-item" id="nav-auth-item"><a class="nav-link" href="/#connexion">Connexion</a></li>
                    </ul>
                    <div class="d-flex align-items-center justify-content-center gap-3 mt-3 mt-lg-0">
                        <a href="#historique" class="text-dark d-flex align-items-center text-decoration-none" title="Historique" style="transition: transform 0.3s ease;">
                            <span class="material-symbols-outlined fs-4" style="color: var(--color-primary); transition: color 0.3s;" onmouseover="this.style.color='var(--color-secondary)'" onmouseout="this.style.color='var(--color-primary)'">history</span>
                        </a>
                        <!-- Icône de Déconnexion Premium Dynamique -->
                        <a href="#explorer" class="btn-premium text-decoration-none text-center">Trouver un Circuit</a>
                        <a href="#" id="btn-logout" class="text-dark d-none d-flex align-items-center text-decoration-none" title="Déconnexion" onclick="logoutUser()" style="transition: transform 0.3s ease;">
                            <span class="material-symbols-outlined fs-4 text-danger" style="transition: opacity 0.3s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">logout</span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <!-- HERO -->
        <section class="position-relative vh-100 d-flex align-items-center justify-content-center overflow-hidden">
            <div class="position-absolute inset-0 w-100 h-100" style="z-index: 0; top: 0; left: 0;">
                <img id="hero-bg" alt="Nosy Be" class="w-100 h-100 object-fit-cover" style="filter: brightness(0.6) contrast(1.02); transform: scale(1.05); will-change: transform;" src="/assets/piscine_nosyBe.png"/>
            </div>
            <div class="position-relative z-1 text-center text-white px-3" style="max-width: 840px; margin-top: 50px;">
                <span class="label-caps d-block mb-3 reveal active" style="color: var(--color-glow-gold); font-size: 13px;">Espace d'Évasion</span>
                <h1 class="font-display display-3 mb-4 letter-magical reveal active fw-bold text-shadow">
                    Planifiez Votre Prochain Voyage
                </h1>
                <div class="golden-separator reveal active"></div>
                <p class="fs-5 mb-5 reveal active font-light italic text-white-50">
                    Sillonnez des routes de latérite rouge et de plages sauvages grâce à nos formules clé en main.
                </p>
                <div class="reveal active">
                    <a href="#explorer" class="btn-premium text-decoration-none">Commencer l'exploration</a>
                </div>
            </div>
        </section>

        <!-- RECHERCHE & FILTRAGE -->
        <section id="explorer" class="bg-sunset-amber py-5">
            <div class="container">
                <div class="search-glass-card p-4 p-lg-5 mt-n5 position-relative z-3">
                    <form id="filter-form" class="row g-3 align-items-end">
                        <div class="col-12 col-md-3">
                            <label class="label-caps text-dark mb-2 d-block" style="font-size: 9px;">Où souhaitez-vous aller ?</label>
                            <div class="input-group" style="background-color: #f5eee5; border-radius: 30px; overflow: hidden; padding: 2px 10px;">
                                <span class="input-group-text bg-transparent border-0 text-muted"><span class="material-symbols-outlined fs-5">search</span></span>
                                <input type="text" id="search-input" class="form-control bg-transparent border-0 py-2 shadow-none" placeholder="Est, Sud, Nosy Be...">
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <label class="label-caps text-dark mb-2 d-block" style="font-size: 9px;">Capacité d'accueil</label>
                            <div class="input-group" style="background-color: #f5eee5; border-radius: 30px; overflow: hidden; padding: 2px 10px;">
                                <select id="capacity-filter" class="form-select bg-transparent border-0 py-2 shadow-none" style="font-size: 13px;">
                                    <option value="all">Toutes</option>
                                    <option value="4">Jusqu'à 4 pers.</option>
                                    <option value="10">Jusqu'à 10 pers.</option>
                                    <option value="20">Plus de 10 pers.</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="label-caps text-dark mb-2 d-block" style="font-size: 9px;">Budget Max (€)</label>
                            <div class="input-group" style="background-color: #f5eee5; border-radius: 30px; overflow: hidden; padding: 2px 10px;">
                                <input type="number" id="price-filter" class="form-control bg-transparent border-0 py-2 shadow-none" placeholder="Ex: 2500 €" style="font-size: 13px;">
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <label class="label-caps text-dark mb-2 d-block" style="font-size: 9px;">Transport</label>
                            <div class="input-group" style="background-color: #f5eee5; border-radius: 30px; overflow: hidden; padding: 2px 10px;">
                                <select id="transport-filter" class="form-select bg-transparent border-0 py-2 shadow-none" style="font-size: 13px;">
                                    <option value="all">Tous</option>
                                    <option value="4x4">4x4</option>
                                    <option value="bateau">Bateau / Vedette</option>
                                    <option value="avion">Avion / Vol interne</option>
                                    <option value="mixte">Combiné / Autre</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-6 col-md-2">
                            <button type="submit" class="btn-premium w-100 py-3 rounded-pill border-0 d-flex justify-content-center align-items-center gap-2">Filtrer</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <!-- CATALOGUE -->
        <section class="bg-sunset-glow section-gap">
            <div class="position-absolute top-0 start-0 watermark-text text-parallax" data-speed-x="-0.2">EXPLORE</div>
            <div class="container position-relative z-1">
                <div class="text-center mb-5 reveal">
                    <span class="label-caps text-secondary d-block mb-2">Nos Catalogues</span>
                    <h2 class="font-display display-6 fw-bold text-dark">Circuits Disponibles</h2>
                    <div class="golden-separator"></div>
                </div>
                <div id="circuits-container" class="d-flex flex-column gap-5 w-100"></div>
            </div>
        </section>

        <!-- HISTORIQUE SÉCURISÉ DES RÉSERVATIONS -->
        <section id="historique" class="bg-sunset-warm section-gap">
            <div class="position-absolute bottom-0 end-0 watermark-text text-parallax" data-speed-x="0.2">JOURNEYS</div>
            <div class="container position-relative z-1">
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-9">
                        <div class="text-center mb-5 reveal">
                            <span class="label-caps text-secondary d-block mb-2">Suivi Personnel</span>
                            <h2 class="font-display display-6 fw-bold text-dark">Mes Réservations</h2>
                            <div class="golden-separator"></div>
                        </div>

                        <div id="history-unauth" class="text-center py-5 p-4 bg-white border reveal">
                            <span class="material-symbols-outlined fs-1 text-muted mb-3">lock</span>
                            <h5 class="font-display text-dark fw-bold mb-3">Accès Sécurisé</h5>
                            <p class="text-muted small mb-4 mx-auto" style="max-width: 420px;">Veuillez vous connecter à votre compte client pour consulter l'historique de vos voyages.</p>
                            <a href="/#connexion" class="btn btn-outline-premium rounded-pill px-4">Se Connecter Maintenant</a>
                        </div>

                        <div id="history-auth" class="d-none reveal">
                            <div id="history-list" class="d-flex flex-column gap-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- MODALE FICHE D'ÉVASION & INFOS EXTENSIBLES -->
    <div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="background-color: var(--color-surface-cream); border-radius: 0px; overflow: hidden;">
                <div class="modal-header border-0 pb-0 px-4 pt-4">
                    <h5 class="font-display fw-bold text-dark mb-0 fs-4">Fiche d'Évasion Privée</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-12 col-lg-6">
                            <div class="overflow-hidden shadow-sm" style="height: 100%; min-height: 280px; border-radius: 0px;">
                                <img id="detail-modal-img" src="" alt="Voyage" class="w-100 h-100 object-fit-cover" onerror="this.src='/assets/baobab3.webp'">
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 d-flex flex-column justify-content-between">
                            <div>
                                <span id="detail-modal-deadline" class="tag-depart d-block mb-1"></span>
                                <h3 id="detail-modal-title" class="font-display italic text-dark fw-bold mb-3" style="font-size: 26px;"></h3>
                                <p id="detail-modal-description" class="text-muted small mb-4" style="line-height: 1.6; text-align: justify; max-height: 180px; overflow-y: auto;"></p>
                                
                                <div class="row g-3 mb-3" style="font-size: 13px;">
                                    <div class="col-6">
                                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 8px; letter-spacing: 0.15em;">CAPACITÉ</span>
                                        <span id="detail-modal-capacity" class="fw-bold text-dark"></span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 8px; letter-spacing: 0.15em;">TARIF LOGISTIQUE</span>
                                        <span id="detail-modal-price" class="fw-bold" style="color: var(--color-secondary);"></span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 8px; letter-spacing: 0.15em;">TRANSPORT</span>
                                        <span id="detail-modal-transport" class="fw-bold text-dark"></span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 8px; letter-spacing: 0.15em;">DATES SÉJOUR</span>
                                        <span id="detail-modal-dates" class="fw-bold text-dark" style="font-size: 11px;"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-2 mt-3">
                                <a id="detail-modal-reserve-btn" href="#" class="btn-concierge-premium text-decoration-none">
                                    <span>RÉSERVER CE VOYAGE</span>
                                    <span class="material-symbols-outlined fs-5">chevron_right</span>
                                </a>
                                <button id="detail-modal-cancel-btn" class="btn btn-outline-danger w-100 py-2 rounded-0 d-none" style="font-size:11px; font-weight:700; letter-spacing:0.12em;"></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-white py-5 mt-auto" style="background-color: var(--color-primary) !important;">
        <div class="container text-center text-md-start">
            <span class="text-white-50" style="font-size: 10px;">© 2026 MADAVOYAGES. TOUS DROITS RÉSERVÉS.</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            // Configuration Canvas Shader WebGL d'Arrière-Plan
            const canvas = document.getElementById('shader-canvas');
            function syncSize() { if(canvas) { canvas.width = window.innerWidth; canvas.height = window.innerHeight; } }
            syncSize(); window.addEventListener('resize', syncSize);
            
            const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
            if (gl) {
                const vs = `attribute vec2 pos;varying vec2 uv;void main() { uv = pos * 0.5 + 0.5; gl_Position = vec4(pos, 0.0, 1.0); }`;
                const fs = `precision highp float;varying vec2 uv;uniform float t;void main() { float n = sin(uv.x * 5.0 + t * 0.2) * cos(uv.y * 4.0 - t * 0.1); vec3 c1 = vec3(0.01, 0.12, 0.1); vec3 c2 = vec3(0.07, 0.04, 0.12); vec3 f = mix(c1, c2, uv.y + n * 0.1); gl_FragColor = vec4(f, 0.12); }`;
                function cs(type, src) { const s = gl.createShader(type); gl.shaderSource(s, src); gl.compileShader(s); return s; }
                const prog = gl.createProgram(); gl.attachShader(prog, cs(gl.VERTEX_SHADER, vs)); gl.attachShader(prog, cs(gl.FRAGMENT_SHADER, fs)); gl.linkProgram(prog); gl.useProgram(prog);
                const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
                const posLoc = gl.getAttribLocation(prog, 'pos'); gl.enableVertexAttribArray(posLoc); gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);
                const tLoc = gl.getUniformLocation(prog, 't');
                function render(timestamp) { gl.viewport(0, 0, canvas.width, canvas.height); if (tLoc) gl.uniform1f(tLoc, timestamp * 0.001); gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4); requestAnimationFrame(render); }
                render(0);
            }

            // Particules Ambiances
            const fContainer = document.getElementById('firefly-container');
            function addFirefly() {
                if (!fContainer || fContainer.children.length > 20) return;
                const f = document.createElement('div');
                f.className = 'firefly'; f.style.left = Math.random() * 100 + 'vw';
                f.style.animationDuration = (Math.random() * 5 + 8) + 's';
                fContainer.appendChild(f); setTimeout(() => f.remove(), 13000);
            }
            setInterval(addFirefly, 1000);

            // Déclencheurs Animations d'Entrée
            const obs = new IntersectionObserver((entries) => {
                entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

            window.addEventListener('scroll', () => {
                const scrolled = window.scrollY;
                const heroBg = document.getElementById('hero-bg');
                if (heroBg) heroBg.style.transform = `scale(1.05) translateY(${scrolled * 0.3}px) translateZ(0)`;
                document.querySelectorAll('.text-parallax').forEach((el) => {
                    const speedX = parseFloat(el.getAttribute('data-speed-x')) || 0.08;
                    el.style.transform = `translate3d(${scrolled * speedX}px, 0, 0)`;
                });
                const header = document.querySelector('header');
                if (scrolled > 50) {
                    header.style.padding = "0px"; header.style.backgroundColor = 'rgba(251, 249, 245, 0.96)';
                } else {
                    header.style.padding = "6px 0px"; header.style.backgroundColor = 'rgba(251, 249, 245, 0.92)';
                }
            });

            let allCircuits = [];
            let currentReservationsRaw = [];
            try {
                const voyagesDataEl = document.getElementById('voyages-data');
                if (voyagesDataEl) allCircuits = JSON.parse(voyagesDataEl.textContent);
            } catch (e) { console.error(e); }

            function formatDate(dStr) {
                if(!dStr) return '';
                return new Date(dStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
            }

            // Rendu Dynamique du Catalogue
            function renderCircuits(circuits) {
                const container = document.getElementById('circuits-container');
                if (!container) return;
                if (!circuits || circuits.length === 0) {
                    container.innerHTML = `<div class="text-center py-5 bg-white border p-4" style="border-radius:0!important;"><p class="text-muted mb-0">Aucun circuit trouvé.</p></div>`;
                    return;
                }

                container.innerHTML = circuits.map((c, index) => {
                    const priceEuro = c.price || 0;
                    const priceAriary = c.price_ariary || (c.price ? c.price * 5000 : 0);
                    const title = c.title || "Circuit d'Exception";
                    const circuitId = c.id || c._id || '';
                    const formattedEuro = new Intl.NumberFormat('fr-FR').format(priceEuro) + ' €';
                    const formattedAriary = new Intl.NumberFormat('fr-FR').format(priceAriary) + ' Ar';
                    let registrationTag = c.date_fin_reservation ? `RÉSERVATION AVANT LE : ${formatDate(c.date_fin_reservation)}` : "ÉDITION LIMITÉE";

                    const isEven = index % 2 === 0;
                    return `
                    <div class="premium-card-hover mb-5 pb-lg-5 w-100">
                        <div class="row g-0 align-items-center w-100 px-3 px-lg-5">
                            <div class="col-12 col-lg-7 ${isEven ? 'order-lg-1' : 'order-lg-2'} zoom-container shadow-sm" style="height:440px; border-radius:0!important;">
                                <img alt="${title}" src="${c.image_url}" class="w-100 h-100 object-fit-cover" onerror="this.src='/assets/baobab3.webp'">
                            </div>
                            <div class="col-12 col-lg-5 ${isEven ? 'order-lg-2 ms-lg-n5' : 'order-lg-1 me-lg-n5'} mt-n5 mt-lg-0" style="z-index:2;">
                                <div class="content-box-hover bg-white p-4 p-lg-5 shadow-lg border-0" style="border-radius:0!important;">
                                    <span class="tag-depart">${registrationTag}</span>
                                    <h3 class="font-display italic text-dark fw-bold my-3" style="font-size:30px;">${title}</h3>
                                    <div class="row g-3 mb-4">
                                        <div class="col-6">
                                            <span class="label-caps text-muted d-block" style="font-size:8px;">PARTICIPANTS</span>
                                            <span class="fw-bold text-dark" style="font-size:13px;">Max ${c.capacity || 4} pers.</span>
                                        </div>
                                        <div class="col-6">
                                            <span class="label-caps text-muted d-block" style="font-size:8px;">INVESTISSEMENT</span>
                                            <span class="fw-bold text-dark" style="font-size:14px;">${formattedEuro}</span>
                                            <span class="small fw-semibold text-secondary d-block">${formattedAriary}</span>
                                        </div>
                                        <div class="col-6">
                                            <span class="label-caps text-muted d-block" style="font-size:8px;">LOGISTIQUE</span>
                                            <span class="fw-bold text-dark" style="font-size:13px;">${c.type_transport || '4x4'}</span>
                                        </div>
                                        <div class="col-6">
                                            <span class="label-caps text-muted d-block" style="font-size:8px;">DÉPART SÉJOUR</span>
                                            <span class="fw-bold text-dark" style="font-size:12px;">${formatDate(c.date_debut_voyage) || "Flexible"}</span>
                                        </div>
                                    </div>
                                    <button onclick="openCatalogDetails('${circuitId}')" class="btn-concierge-premium">
                                        <span>PLUS D'INFORMATIONS</span><span class="material-symbols-outlined fs-5">arrow_forward</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>`;
                }).join('');
            }

            // Rendu de l'Historique Épuré
            async function fetchHistory() {
                const token = localStorage.getItem('token');
                const authBlock = document.getElementById('history-auth');
                const unauthBlock = document.getElementById('history-unauth');
                const listContainer = document.getElementById('history-list');

                if (!token) return;
                if (authBlock) authBlock.classList.remove('d-none');
                if (unauthBlock) unauthBlock.classList.add('d-none');

                try {
                    const response = await fetch('/api/reservations/mon-historique', {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if (!response.ok) throw new Error();
                    const reservations = await response.json();
                    currentReservationsRaw = reservations;
                    
                    if (reservations.length === 0) {
                        listContainer.innerHTML = `<div class="text-center py-5 bg-white border" style="border-radius:0!important;"><p class="text-muted small mb-0">Aucune demande active.</p></div>`;
                        return;
                    }

                    listContainer.innerHTML = reservations.map(r => {
                        const dateRef = r.date_debut_voyage ? formatDate(r.date_debut_voyage) : 'À planifier';
                        const badgeColor = r.statut === 'valide' ? 'bg-success' : (r.statut === 'annule' ? 'bg-danger' : 'bg-warning text-dark');
                        const cardStatusClass = r.statut === 'valide' ? 'valide' : (r.statut === 'annule' ? 'annule' : '');

                        return `
                            <div class="history-card ${cardStatusClass} p-4 mb-2 bg-white">
                                <div class="row align-items-center g-3">
                                    <div class="col-12 col-md-8">
                                        <div class="d-flex align-items-center gap-3 mb-2">
                                            <span class="badge ${badgeColor} label-caps px-3 py-2 rounded-pill" style="font-size:8px; font-weight:700;">${r.statut.toUpperCase()}</span>
                                            <span class="text-muted small">Départ : ${dateRef}</span>
                                        </div>
                                        <h5 class="font-display fw-bold text-dark mb-0">${r.title || 'Circuit Privé d\'Exception'}</h5>
                                    </div>
                                    <div class="col-12 col-md-4 text-md-end">
                                        <button onclick="openReservationDetails('${r.id || r._id}')" class="btn btn-outline-premium rounded-pill px-4" style="font-size:11px; font-weight:700; letter-spacing:0.05em;">
                                            VOIR L'ÉVASION
                                        </button>
                                    </div>
                                </div>
                            </div>`;
                    }).join('');
                } catch (err) {
                    listContainer.innerHTML = `<p class="text-danger small text-center">Échec de synchronisation des informations.</p>`;
                }
            }

            // Ouvre la pop-up pour les éléments de l'historique
            window.openReservationDetails = function(resId) {
                const res = currentReservationsRaw.find(item => String(item.id || item._id) === String(resId));
                if (!res) return;

                const startD = formatDate(res.date_debut_voyage);
                const endD = formatDate(res.date_fin_voyage);
                const seats = res.nombre_personnes || (res.places_choisies ? res.places_choisies.length : 1);

                document.getElementById('detail-modal-img').src = res.image_url || '/assets/baobab3.webp';
                document.getElementById('detail-modal-title').textContent = res.title || "Circuit Privé d'Exception";
                document.getElementById('detail-modal-description').textContent = res.description || "Détails personnalisés enregistrés pour votre demande d'évasion privée.";
                document.getElementById('detail-modal-capacity').textContent = res.places_choisies ? `Sièges : ${res.places_choisies.join(', ')}` : `${seats} Voyageur(s)`;
                document.getElementById('detail-modal-price').textContent = res.prix_total ? `${new Intl.NumberFormat('fr-FR').format(res.prix_total)} €` : "Sur mesure";
                document.getElementById('detail-modal-transport').textContent = res.type_transport || "Véhicule Privé 4x4";
                document.getElementById('detail-modal-dates').textContent = (startD && endD) ? `Du ${startD} au ${endD}` : "Dates réservées";
                document.getElementById('detail-modal-deadline').textContent = `STATUT ACTUEL : ${res.statut.toUpperCase()}`;
                
                document.getElementById('detail-modal-reserve-btn').classList.add('d-none');
                
                const cancelBtn = document.getElementById('detail-modal-cancel-btn');
                if (res.statut === 'en_attente') {
                    cancelBtn.classList.remove('d-none');
                    cancelBtn.textContent = "ANNULER LA RÉSERVATION";
                    cancelBtn.onclick = () => { cancelReservation(res.id || res._id); };
                } else {
                    cancelBtn.classList.add('d-none');
                }

                new bootstrap.Modal(document.getElementById('detailsModal')).show();
            };

            // Ouvre la pop-up pour les éléments du catalogue général
            window.openCatalogDetails = function(id) {
                const circuit = allCircuits.find(c => String(c.id || c._id) === String(id));
                if (!circuit) return;

                const formattedEuro = new Intl.NumberFormat('fr-FR').format(circuit.price || 0) + ' €';
                const formattedAriary = ` / ${new Intl.NumberFormat('fr-FR').format(circuit.price_ariary || 0)} Ar`;
                const startD = formatDate(circuit.date_debut_voyage);
                const endD = formatDate(circuit.date_fin_voyage);

                document.getElementById('detail-modal-img').src = circuit.image_url;
                document.getElementById('detail-modal-title').textContent = circuit.title || 'Voyage Exceptionnel';
                document.getElementById('detail-modal-description').textContent = circuit.description || "Aucune description disponible.";
                document.getElementById('detail-modal-capacity').textContent = `${circuit.capacity || 4} Voyageurs max`;
                document.getElementById('detail-modal-price').textContent = `${formattedEuro}${formattedAriary}`;
                document.getElementById('detail-modal-transport').textContent = circuit.type_transport || "Spécifié";
                document.getElementById('detail-modal-dates').textContent = (startD && endD) ? `Du ${startD} au ${endD}` : "Dates flexibles";
                document.getElementById('detail-modal-deadline').textContent = circuit.date_fin_reservation ? `RÉSERVEZ AVANT LE : ${formatDate(circuit.date_fin_reservation)}` : "DÉPART ASSURÉ";

                const reserveBtn = document.getElementById('detail-modal-reserve-btn');
                reserveBtn.classList.remove('d-none');
                reserveBtn.href = `/reservations?circuit_id=${circuit.id || circuit._id}`;
                
                document.getElementById('detail-modal-cancel-btn').classList.add('d-none');

                new bootstrap.Modal(document.getElementById('detailsModal')).show();
            };

            window.cancelReservation = async function(id) {
                if(!confirm("Êtes-vous sûr de vouloir annuler cette demande d'évasion ?")) return;
                try {
                    const response = await fetch(`/api/reservations/${id}/annuler`, {
                        method: 'PUT',
                        headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                    });
                    const resData = await response.json();
                    if (response.ok) {
                        bootstrap.Modal.getInstance(document.getElementById('detailsModal')).hide();
                        fetchHistory();
                    } else {
                        alert(resData.message || "Erreur lors de l'annulation.");
                    }
                } catch (err) { 
                    alert("Erreur de communication réseau avec le serveur."); 
                }
            };

            window.logoutUser = function() {
                localStorage.removeItem('token');
                window.location.reload();
            };

            renderCircuits(allCircuits);
            fetchHistory();

            const navAuthItem = document.getElementById('nav-auth-item');
            const btnLogout = document.getElementById('btn-logout');
            if (localStorage.getItem('token')) {
                if (navAuthItem) navAuthItem.innerHTML = `<a class="nav-link" href="#historique" style="color:var(--color-secondary)!important;">Mon Espace</a>`;
                if (btnLogout) btnLogout.classList.remove('d-none');
            }
        })();
    </script>
</body>
</html>